<!doctype html>
<html lang="en" class="h-full bg-zinc-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Relay Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/lucide-static"></script>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono&display=swap");
      body {
        font-family: "Inter", sans-serif;
      }
      .mono {
        font-family: "JetBrains Mono", monospace;
      }
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #09090b;
      }
      ::-webkit-scrollbar-thumb {
        background: #27272a;
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3f3f46;
      }
    </style>
  </head>
  <body class="h-full text-zinc-300 antialiased">
    <div id="root" class="h-full"></div>

    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script type="text/babel" data-presets="react">
      const { useState, useEffect, useRef } = React;

      const API_BASE = window.location.origin;

      function App() {
        const [token, setToken] = useState(
          sessionStorage.getItem("relay_token"),
        );
        const [view, setView] = useState("deploys"); // 'deploys' | 'apps' | 'logs' | 'secrets'
        const [deploys, setDeploys] = useState([]);
        const [apps, setApps] = useState([]);
        const [selectedDeploy, setSelectedDeploy] = useState(null);
        const [selectedApp, setSelectedApp] = useState(null); // { app, env, branch }
        const [loading, setLoading] = useState(false);
        const [error, setError] = useState(null);

        const fetchAPI = async (path, options = {}) => {
          const res = await fetch(`${API_BASE}${path}`, {
            ...options,
            headers: {
              ...options.headers,
              "X-Relay-Token": token,
              "Content-Type": "application/json",
            },
          });
          if (res.status === 401 || res.status === 403) {
            setToken(null);
            sessionStorage.removeItem("relay_token");
            throw new Error("Unauthorized");
          }
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || "API Error");
          return data;
        };

        const loadDeploys = async () => {
          try {
            setLoading(true);
            const data = await fetchAPI("/api/deploys");
            setDeploys(data || []);
          } catch (err) {
            setError(err.message);
          } finally {
            setLoading(false);
          }
        };

        const loadApps = async () => {
          try {
            setLoading(true);
            const data = await fetchAPI("/api/deploys");
            const unique = {};
            (data || []).forEach((d) => {
              const key = d.app;
              if (!unique[key]) unique[key] = { name: d.app, envs: {} };
              const envKey = `${d.env}__${d.branch}`;
              unique[key].envs[envKey] = { env: d.env, branch: d.branch };
            });
            setApps(Object.values(unique));
          } catch (err) {
            setError(err.message);
          } finally {
            setLoading(false);
          }
        };

        useEffect(() => {
          if (token) {
            if (view === "deploys") loadDeploys();
            if (view === "apps") loadApps();
          }
        }, [token, view]);

        if (!token) {
          return (
            <Login
              onLogin={(t) => {
                setToken(t);
                sessionStorage.setItem("relay_token", t);
              }}
            />
          );
        }

        return (
          <div className="flex h-full flex-col">
            <header className="flex items-center justify-between border-b border-zinc-800 bg-zinc-900/50 px-6 py-4 backdrop-blur-md">
              <div className="flex items-center gap-3">
                <div className="h-8 w-8 rounded-lg bg-indigo-600 flex items-center justify-center font-bold text-white italic">
                  R
                </div>
                <h1 className="text-lg font-semibold text-white tracking-tight">
                  Relay Dashboard
                </h1>
              </div>
              <div className="flex items-center gap-4"></div>
            </header>

            <div className="flex flex-1 overflow-hidden">
              <aside className="w-64 border-r border-zinc-800 bg-zinc-900/30 p-4 flex flex-col gap-1">
                <NavItem
                  active={view === "deploys" || view === "logs"}
                  onClick={() => setView("deploys")}
                  label="Deployments"
                />
                <NavItem
                  active={view === "apps" || view === "secrets"}
                  onClick={() => setView("apps")}
                  label="Apps & Secrets"
                />
              </aside>

              <main className="flex-1 overflow-auto bg-zinc-950 p-6">
                {error && (
                  <div className="mb-4 rounded-lg bg-red-900/20 border border-red-500/50 p-4 text-red-400 text-sm flex justify-between items-center">
                    <span>{error}</span>
                    <button onClick={() => setError(null)}>&times;</button>
                  </div>
                )}

                {view === "deploys" && (
                  <DeployList
                    deploys={deploys}
                    loading={loading}
                    onRefresh={loadDeploys}
                    onSelect={(d) => {
                      setSelectedDeploy(d);
                      setView("logs");
                    }}
                  />
                )}

                {view === "apps" && (
                  <AppList
                    apps={apps}
                    loading={loading}
                    onRefresh={loadApps}
                    onSelect={(app, env, br) => {
                      setSelectedApp({ app, env, branch: br });
                      setView("secrets");
                    }}
                  />
                )}

                {view === "secrets" && selectedApp && (
                  <SecretManager
                    app={selectedApp}
                    fetchAPI={fetchAPI}
                    onBack={() => setView("apps")}
                  />
                )}

                {view === "logs" && selectedDeploy && (
                  <LogViewer
                    deploy={selectedDeploy}
                    token={token}
                    onClose={() => setView("deploys")}
                  />
                )}
              </main>
            </div>
          </div>
        );
      }

      function NavItem({ active, label, onClick }) {
        return (
          <button
            onClick={onClick}
            className={`flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-colors ${active ? "bg-indigo-600/10 text-indigo-400" : "text-zinc-500 hover:bg-zinc-800/50 hover:text-zinc-300"}`}
          >
            <span className="opacity-70">{label}</span>
          </button>
        );
      }

      function Login({ onLogin }) {
        const [val, setVal] = useState("");
        return (
          <div className="flex h-full items-center justify-center bg-zinc-950 px-4">
            <div className="w-full max-w-sm rounded-2xl border border-zinc-800 bg-zinc-900/50 p-8 shadow-2xl backdrop-blur-xl">
              <div className="mb-8 text-center">
                <div className="mx-auto mb-4 h-12 w-12 rounded-xl bg-indigo-600 flex items-center justify-center font-bold text-white text-xl italic shadow-lg shadow-indigo-500/20">
                  R
                </div>
                <h2 className="text-2xl font-bold text-white tracking-tight">
                  Welcome to Relay
                </h2>
                <p className="mt-2 text-zinc-500 text-sm">
                  Enter your agent token to continue
                </p>
              </div>
              <form
                onSubmit={(e) => {
                  e.preventDefault();
                  onLogin(val);
                }}
                className="space-y-4"
              >
                <div>
                  <input
                    type="password"
                    required
                    placeholder="Agent Token (RELAY_TOKEN)"
                    className="w-full rounded-lg border border-zinc-800 bg-black/40 px-4 py-3 text-sm text-white placeholder-zinc-600 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all shadow-inner"
                    value={val}
                    onChange={(e) => setVal(e.target.value)}
                  />
                  <p className="mt-2 text-[10px] text-zinc-600 px-1">
                    Check{" "}
                    <code className="bg-zinc-800 rounded px-1">
                      data/token.txt
                    </code>{" "}
                    on the host machine.
                  </p>
                </div>
                <button className="w-full rounded-lg bg-indigo-600 py-3 text-sm font-semibold text-white hover:bg-indigo-500 transition-all shadow-lg shadow-indigo-600/25 active:scale-[0.98]">
                  Authenticate
                </button>
              </form>
            </div>
          </div>
        );
      }

      function DeployList({ deploys, loading, onRefresh, onSelect }) {
        return (
          <div>
            <div className="flex items-center justify-between mb-6">
              <h2 className="text-xl font-bold text-white tracking-tight">
                Recent Deployments
              </h2>
              <button
                onClick={onRefresh}
                className="rounded-lg border border-zinc-800 bg-zinc-900/80 px-4 py-2 text-xs font-medium text-zinc-400 hover:text-white transition-all"
              >
                Refresh
              </button>
            </div>

            <div className="grid gap-4">
              {deploys.length === 0 && !loading && (
                <div className="py-12 text-center text-zinc-600 border border-dashed border-zinc-800 rounded-xl">
                  No deployments found yet.
                </div>
              )}
              {deploys.map((d) => (
                <div
                  key={d.id}
                  onClick={() => onSelect(d)}
                  className="group cursor-pointer rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition-all hover:bg-zinc-900/60 hover:border-zinc-700 active:scale-[0.99]"
                >
                  <div className="flex items-start justify-between">
                    <div className="flex-1">
                      <div className="flex items-center gap-3 mb-2">
                        <span className="text-base font-semibold text-white tracking-tight">
                          {d.app}
                        </span>
                        <span
                          className={`rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider ${d.env === "prod" ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" : "bg-blue-500/10 text-blue-400 border border-blue-500/20"}`}
                        >
                          {d.env}
                        </span>
                        <span
                          className={`rounded-md px-2 py-0.5 text-[10px] font-bold uppercase transition-colors ${
                            d.status === "success"
                              ? "text-emerald-400"
                              : d.status === "failed"
                                ? "text-red-400"
                                : "text-amber-400 animate-pulse"
                          }`}
                        >
                          {d.status}
                        </span>
                      </div>
                      <div className="flex gap-4 text-xs text-zinc-500 mono">
                        <span className="flex items-center gap-1.5">
                          <span className="opacity-50">branch:</span>
                          {d.branch}
                        </span>
                        <span className="flex items-center gap-1.5">
                          <span className="opacity-50">id:</span>
                          {d.id.slice(0, 8)}
                        </span>
                        <span className="flex items-center gap-1.5">
                          <span className="opacity-50">at:</span>
                          {new Date(d.created_at).toLocaleString()}
                        </span>
                      </div>
                    </div>
                    <div className="text-zinc-700 group-hover:text-zinc-500 transition-colors">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        strokeWidth="2"
                        strokeLinecap="round"
                        strokeLinejoin="round"
                      >
                        <path d="m9 18 6-6-6-6" />
                      </svg>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      }

      function AppList({ apps, loading, onRefresh, onSelect }) {
        return (
          <div>
            <div className="flex items-center justify-between mb-6">
              <h2 className="text-xl font-bold text-white tracking-tight">
                Applications
              </h2>
              <button
                onClick={onRefresh}
                className="rounded-lg border border-zinc-800 bg-zinc-900/80 px-4 py-2 text-xs font-medium text-zinc-400 hover:text-white transition-all"
              >
                Refresh
              </button>
            </div>

            <div className="grid gap-6">
              {apps.length === 0 && !loading && (
                <div className="py-12 text-center text-zinc-600 border border-dashed border-zinc-800 rounded-xl">
                  No apps detected yet. Run a deployment first.
                </div>
              )}
              {apps.map((app) => (
                <div
                  key={app.name}
                  className="rounded-xl border border-zinc-800 bg-zinc-900/40 overflow-hidden"
                >
                  <div className="bg-zinc-900/60 border-b border-zinc-800 px-5 py-3 flex items-center justify-between">
                    <span className="text-white font-semibold">{app.name}</span>
                  </div>
                  <div className="p-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
                    {Object.values(app.envs).map((e) => (
                      <button
                        key={`${e.env}-${e.branch}`}
                        onClick={() => onSelect(app.name, e.env, e.branch)}
                        className="flex items-center justify-between rounded-lg border border-zinc-800 bg-zinc-900 p-3 hover:bg-zinc-800 hover:border-zinc-700 transition-all text-left"
                      >
                        <div className="flex flex-col">
                          <span
                            className={`text-[10px] font-bold uppercase ${e.env === "prod" ? "text-emerald-400" : "text-blue-400"}`}
                          >
                            {e.env}
                          </span>
                          <span className="text-xs text-zinc-300 truncate max-w-[120px]">
                            {e.branch}
                          </span>
                        </div>
                        <div className="text-zinc-600 text-[10px] font-mono">
                          Secrets &rarr;
                        </div>
                      </button>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      }

      function SecretManager({ app, fetchAPI, onBack }) {
        const [secrets, setSecrets] = useState([]);
        const [loading, setLoading] = useState(false);
        const [newSecret, setNewSecret] = useState({ key: "", value: "" });

        const load = async () => {
          setLoading(true);
          try {
            const data = await fetchAPI(
              `/api/apps/secrets?app=${app.app}&env=${app.env}&branch=${app.branch}`,
            );
            setSecrets(data || []);
          } catch (e) {
            console.error(e);
          }
          setLoading(false);
        };

        const add = async () => {
          if (!newSecret.key || !newSecret.value) return;
          try {
            await fetchAPI("/api/apps/secrets", {
              method: "POST",
              body: JSON.stringify({ ...app, ...newSecret }),
            });
            setNewSecret({ key: "", value: "" });
            load();
          } catch (e) {
            alert(e.message);
          }
        };

        const remove = async (key) => {
          if (!confirm("Remove this secret?")) return;
          try {
            await fetchAPI(
              `/api/apps/secrets?app=${app.app}&env=${app.env}&branch=${app.branch}&key=${key}`,
              { method: "DELETE" },
            );
            load();
          } catch (e) {
            alert(e.message);
          }
        };

        useEffect(() => {
          load();
        }, []);

        return (
          <div className="max-w-4xl mx-auto">
            <div className="flex items-center gap-3 mb-6">
              <button
                onClick={onBack}
                className="rounded-lg p-2 text-zinc-500 hover:bg-zinc-800 transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  strokeWidth="2"
                  strokeLinecap="round"
                  strokeLinejoin="round"
                  className="rotate-180"
                >
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </button>

              <div>
                <h2 className="text-xl font-bold text-white tracking-tight">
                  Secrets Management
                </h2>
                <p className="text-xs text-zinc-500 mt-1">
                  {app.app} <span className="mx-1">•</span> {app.env}{" "}
                  <span className="mx-1">•</span> {app.branch}
                </p>
              </div>
            </div>

            <div className="space-y-6">
              <div className="rounded-xl border border-zinc-800 bg-zinc-900/40 p-5">
                <h3 className="text-sm font-semibold text-white mb-4">
                  Add Secret
                </h3>

                <div className="flex gap-3">
                  <input
                    className="flex-1 rounded-lg border border-zinc-800 bg-black/40 px-4 py-2 text-sm text-white placeholder-zinc-600 focus:border-indigo-500 outline-none"
                    placeholder="KEY (e.g. DATABASE_URL)"
                    value={newSecret.key}
                    onChange={(e) =>
                      setNewSecret({ ...newSecret, key: e.target.value })
                    }
                  />

                  <input
                    className="flex-1 rounded-lg border border-zinc-800 bg-black/40 px-4 py-2 text-sm text-white placeholder-zinc-600 focus:border-indigo-500 outline-none"
                    placeholder="VALUE"
                    type="password"
                    value={newSecret.value}
                    onChange={(e) =>
                      setNewSecret({ ...newSecret, value: e.target.value })
                    }
                  />

                  <button
                    onClick={add}
                    className="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-indigo-500 transition-colors"
                  >
                    Add
                  </button>
                </div>
              </div>

              <div className="rounded-xl border border-zinc-800 bg-zinc-900/40 overflow-hidden">
                <table className="w-full text-left text-sm">
                  <thead className="bg-zinc-900/60 border-b border-zinc-800 text-zinc-500">
                    <tr>
                      <th className="px-5 py-3 font-medium">Key</th>
                      <th className="px-5 py-3 font-medium text-right">
                        Action
                      </th>
                    </tr>
                  </thead>

                  <tbody className="divide-y divide-zinc-800">
                    {secrets.length === 0 && !loading && (
                      <tr>
                        <td
                          colSpan="2"
                          className="px-5 py-8 text-center text-zinc-600 italic"
                        >
                          No secrets defined for this scope.
                        </td>
                      </tr>
                    )}

                    {secrets.map((s) => (
                      <tr key={s.key} className="hover:bg-zinc-800/20">
                        <td className="px-5 py-3 font-mono text-indigo-400">
                          {s.key}
                        </td>
                        <td className="px-5 py-3 text-right">
                          <button
                            onClick={() => remove(s.key)}
                            className="text-zinc-500 hover:text-red-400 text-xs"
                          >
                            Delete
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        );
      }

      function LogViewer({ deploy, token, onClose }) {
        const [logs, setLogs] = useState([]);
        const scrollRef = useRef();

        useEffect(() => {
          const url = `${API_BASE}/api/logs/stream/${deploy.id}`;
          const evSource = new EventSource(`${url}?token=${token}`); // Note: middleware updated to support token param

          evSource.onmessage = (e) => {
            setLogs((prev) => [...prev, e.data]);
            if (scrollRef.current) {
              scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
            }
          };
          evSource.onerror = () => evSource.close();
          return () => evSource.close();
        }, [deploy.id, token]);

        return (
          <div className="flex h-full flex-col">
            <div className="flex items-center justify-between mb-6">
              <div className="flex items-center gap-3">
                <button
                  onClick={onClose}
                  className="rounded-lg p-2 text-zinc-500 hover:bg-zinc-800 transition-colors"
                >
                <svg
  xmlns="http://www.w3.org/2000/svg"
  width="20"
  height="20"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  strokeWidth="2"
  strokeLinecap="round"
  strokeLinejoin="round"
  className="rotate-180"
>
  <path d="m9 18 6-6-6-6" />
</svg>

                </button>
                <div>
                  <h2 className="text-xl font-bold text-white tracking-tight">
                    Deployment Logs
                  </h2>
                  <p className="text-xs text-zinc-500 mt-1">
                    {deploy.app} <span className="mx-1">•</span> {deploy.id}
                  </p>
                </div>
              </div>
            </div>

            <div
              ref={scrollRef}
              className="flex-1 overflow-auto rounded-xl border border-zinc-800 bg-black/60 p-6 mono text-[13px] leading-relaxed text-zinc-400 whitespace-pre-wrap selection:bg-indigo-500/30 shadow-inner"
            >
              {logs.length === 0 && (
                <div className="text-zinc-700 italic">Waiting for logs...</div>
              )}
              {logs.map((line, i) => (
                <div
                  key={i}
                  className="hover:bg-zinc-900/50 transition-colors py-0.5"
                >
                  {line}
                </div>
              ))}
            </div>
          </div>
        );
      }

      const root = ReactDOM.createRoot(document.getElementById("root"));
      root.render(<App />);
    </script>
  </body>
</html>
