# Normalize line endings
* text=auto

# Force LF for Go, JS, shell scripts
*.go text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Windows scripts stay CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries
*.exe binary
*.dll binary
*.so binary
*.wasm binary
